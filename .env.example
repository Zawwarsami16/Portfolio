# ─────────────────────────────────────────────
#  ZAI Portfolio — Environment Variables
#  Copy this file to .env and fill in your keys
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# Your GitHub username — portfolio pulls live data from this
VITE_GH_USER=zawwarsami16

# AI Chat — pick ONE provider and add its key
# OpenRouter (free models available) → https://openrouter.ai
VITE_AI_PROVIDER=openrouter
VITE_AI_KEY=your_key_here

# Optional: override the default model
# VITE_AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
